		<Row>
			<ModifierId>BLACK_KNIGHTS_COMMAND_IDENTITY_PER_TURN_MODIFIER</ModifierId>
			<ModifierType>MODIFIER_SINGLE_CITY_ADJUST_IDENTITY_PER_TURN</ModifierType>
		</Row>
		<!--注册一个叫作BLACK_KNIGHTS_GRANT_PLAYER_GOVERNOR_POINTS的Modifier,绑定的ModifierType是MODIFIER_ALL_PLAYERS_ADJUST_GOVERNOR_POINTS，
