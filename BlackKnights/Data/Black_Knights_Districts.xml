		</Row>
	</Modifiers>
	<ModifierArguments>
		<!--Amount是每回合增加的值，Delta只是触发一个即时的增量，比如此处就是建成黑色骑士团司令部时奖励一个总督头衔，而非每个回合奖励一个-->
		<Row>
			<ModifierId>BLACK_KNIGHTS_COMMAND_IDENTITY_PER_TURN_MODIFIER</ModifierId>
			<Name>Amount</Name>
			<Value>8</Value>
		</Row>
		<Row>
			<ModifierId>BLACK_KNIGHTS_COMMAND_GRANT_PLAYER_GOVERNOR_POINTS</ModifierId>
			<Name>Delta</Name>
			<Value>1</Value>
		</Row>
	</ModifierArguments>
